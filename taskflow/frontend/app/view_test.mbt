// ── Chinese locale ───────────────────────────────────────────────────

///|
test "view renders login screen in Chinese" {
  let model = { ..empty_model(), auth_screen: "login", lang: Zh }
  inspect(render(model.view(noop_dispatch)), content=(
    #|<div style="min-height: 100vh;display: flex;align-items: center;justify-content: center;background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%)"><div style="background: white;border-radius: 16px;padding: 40px;width: 380px;box-shadow: 0 20px 60px rgba(0,0,0,0.3)"><h1 style="color: #1e293b;font-size: 24px;font-weight: 700;text-align: center;margin-bottom: 8px">任务流</h1><p style="color: #64748b;font-size: 14px;text-align: center;margin-bottom: 24px">登录</p><div style="margin-bottom: 14px"><label style="display: block;font-size: 13px;font-weight: 500;color: #64748b;margin-bottom: 4px">用户名</label><input type="text" autocomplete="off" placeholder="请输入用户名" style="width: 100%;padding: 10px 12px;border-radius: 8px;border: 1px solid #e2e8f0;background: white;color: #1e293b;font-size: 14px;box-sizing: border-box;outline: none" value=""></input></div><div style="margin-bottom: 20px"><label style="display: block;font-size: 13px;font-weight: 500;color: #64748b;margin-bottom: 4px">密码</label><input type="password" autocomplete="off" placeholder="请输入密码" style="width: 100%;padding: 10px 12px;border-radius: 8px;border: 1px solid #e2e8f0;background: white;color: #1e293b;font-size: 14px;box-sizing: border-box;outline: none" value=""></input></div><button style="width: 100%;padding: 12px;border: none;border-radius: 8px;cursor: pointer;font-size: 14px;font-weight: 600;color: white;background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);margin-bottom: 12px;opacity: 1">登录</button><div style="text-align: center"><button style="background: none;border: none;color: #6366f1;cursor: pointer;font-size: 13px;padding: 0">没有账户？点此注册</button></div><div style="text-align: center;margin-top: 16px"><button style="background: none;border: 1px solid #6366f1;color: #6366f1;cursor: pointer;font-size: 12px;padding: 4px 12px;border-radius: 12px">EN</button></div></div></div>
  ))
}
