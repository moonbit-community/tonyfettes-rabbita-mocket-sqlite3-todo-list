// ── Loading ──────────────────────────────────────────────────────────

///|
test "view shows loading indicator" {
  let model = {
    ..logged_in_model(),
    loading: true,
  }
  inspect(render(model.view(noop_dispatch)), content=(
    #|<div tabindex="0" style="padding: 16px 24px;min-height: 100vh;max-width: 900px;margin: 0 auto;outline: none;background: #f8fafc;color: #1e293b"><div style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);padding: 20px 32px;margin-bottom: 16px;border-radius: 12px;display: flex;justify-content: space-between;align-items: center"><div><h1 style="color: white;font-size: 22px;font-weight: 700;letter-spacing: -0.3px;margin-bottom: 4px">TaskFlow</h1><div style="color: rgba(255,255,255,0.8);font-size: 13px">0% complete<span style="margin-left: 12px;color: rgba(255,255,255,0.6)">0/0 tasks done</span></div></div><div style="display: flex;align-items: center;gap: 12px"><div style="width: 120px;height: 6px;background: rgba(255,255,255,0.2);border-radius: 3px;overflow: hidden"><div style="width: 0%;height: 100%;background: #a5f3fc;border-radius: 3px;transition: width 0.3s"></div></div><div style="display: flex;gap: 2px"><button style="padding: 6px 10px;border: none;cursor: pointer;font-size: 12px;color: white;border-radius: 4px 0 0 4px;background: rgba(255,255,255,0.1)">List</button><button style="padding: 6px 10px;border: none;cursor: pointer;font-size: 12px;color: white;border-radius: 0 4px 4px 0;background: rgba(255,255,255,0.3)">Board</button></div><button style="padding: 6px 10px;border: none;cursor: pointer;font-size: 12px;color: white;border-radius: 4px;background: rgba(255,255,255,0.1);font-weight: 500">My Tasks</button><button style="padding: 6px 10px;border: none;cursor: pointer;font-size: 12px;color: white;border-radius: 4px;background: rgba(255,255,255,0.15)">Dark</button><button style="padding: 6px 10px;border: none;cursor: pointer;font-size: 12px;color: white;border-radius: 4px;background: rgba(255,255,255,0.15)">中文</button><button style="padding: 8px 16px;background: rgba(255,255,255,0.2);color: white;border: 1px solid rgba(255,255,255,0.3);border-radius: 6px;cursor: pointer;font-size: 13px">+ New Task</button><div style="display: flex;align-items: center;gap: 8px;margin-left: 8px"><div style="width: 28px;height: 28px;border-radius: 50%;display: flex;align-items: center;justify-content: center;font-size: 12px;font-weight: 600;color: white;background: #3b82f6">a</div><span style="color: rgba(255,255,255,0.9);font-size: 13px;font-weight: 500">alice</span><button style="padding: 4px 10px;border: none;cursor: pointer;font-size: 11px;color: rgba(255,255,255,0.8);border-radius: 4px;background: rgba(255,255,255,0.1)">Logout</button></div></div></div><div style="text-align: center;padding: 60px 0;color: #94a3b8;font-size: 15px">Loading...</div></div>
  ))
}

