// TODO(upstream): Add `derive(Debug)` to `Html` / `VNode` in rabbita so view
// tests can use `debug_inspect` snapshots (like update tests) instead of
// rendering to HTML strings.
//
// TODO: Write an html beautify/pretty-print function so rendered snapshots are
// human-readable (indented, one-tag-per-line) instead of single-line blobs.
//
// TODO(upstream): `App::with_init` missing `#cfg(target="js")` blocks native
// SSR — see https://github.com/moonbit-community/rabbita/issues/110
// Once fixed, `render_to_string(static_cell(html))` works on native target,
// enabling server-side rendering from the backend. The Html DSL, Cell,
// static_cell, and render_to_string are all already target-agnostic.
// To do native SSR:
//   1. Patch or wait for rabbita fix (one-line `#cfg` guard)
//   2. Change frontend/app `supported_targets` from "js" to "all"
//   3. Guard `update.mbt` HTTP imports with `#cfg(target="js")`
//   4. Backend imports frontend/app, calls `model.view(noop_dispatch)`
//   5. Use `render_to_string(static_cell(html))` to produce the HTML string
//   6. Inject into the HTML shell instead of empty `<div id="app"></div>`

///|
/// Render an `Html` node to its HTML string representation for test assertions.
#warnings("-alert_unstable")
fn render(html : @rabbita.Html) -> String {
  @rabbita.render_to_string(@rabbita.static_cell(html))
}

// ── Auth screen ──────────────────────────────────────────────────────

///|
test "view shows login screen when auth_screen is login" {
  let model = { ..empty_model(), auth_screen: "login" }
  inspect(render(model.view(noop_dispatch)), content=(
    #|<div style="min-height: 100vh;display: flex;align-items: center;justify-content: center;background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%)"><div style="background: white;border-radius: 16px;padding: 40px;width: 380px;box-shadow: 0 20px 60px rgba(0,0,0,0.3)"><h1 style="color: #1e293b;font-size: 24px;font-weight: 700;text-align: center;margin-bottom: 8px">TaskFlow</h1><p style="color: #64748b;font-size: 14px;text-align: center;margin-bottom: 24px">Sign In</p><div style="margin-bottom: 14px"><label style="display: block;font-size: 13px;font-weight: 500;color: #64748b;margin-bottom: 4px">Username</label><input type="text" autocomplete="off" placeholder="Enter username" style="width: 100%;padding: 10px 12px;border-radius: 8px;border: 1px solid #e2e8f0;background: white;color: #1e293b;font-size: 14px;box-sizing: border-box;outline: none" value=""></input></div><div style="margin-bottom: 20px"><label style="display: block;font-size: 13px;font-weight: 500;color: #64748b;margin-bottom: 4px">Password</label><input type="password" autocomplete="off" placeholder="Enter password" style="width: 100%;padding: 10px 12px;border-radius: 8px;border: 1px solid #e2e8f0;background: white;color: #1e293b;font-size: 14px;box-sizing: border-box;outline: none" value=""></input></div><button style="width: 100%;padding: 12px;border: none;border-radius: 8px;cursor: pointer;font-size: 14px;font-weight: 600;color: white;background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);margin-bottom: 12px;opacity: 1">Sign In</button><div style="text-align: center"><button style="background: none;border: none;color: #6366f1;cursor: pointer;font-size: 13px;padding: 0">Need an account? Register</button></div><div style="text-align: center;margin-top: 16px"><button style="background: none;border: 1px solid #6366f1;color: #6366f1;cursor: pointer;font-size: 12px;padding: 4px 12px;border-radius: 12px">中文</button></div></div></div>
  ))
}

