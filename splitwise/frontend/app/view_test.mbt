// TODO(upstream): Add `derive(Debug)` to `Html` / `VNode` in rabbita so view
// tests can use `debug_inspect` snapshots (like update tests) instead of
// rendering to HTML strings.
//
// TODO: Write an html beautify/pretty-print function so rendered snapshots are
// human-readable (indented, one-tag-per-line) instead of single-line blobs.
//
// TODO(upstream): `App::with_init` missing `#cfg(target="js")` blocks native
// SSR — see https://github.com/moonbit-community/rabbita/issues/110
// Once fixed, `render_to_string(static_cell(html))` works on native target,
// enabling server-side rendering from the backend. The Html DSL, Cell,
// static_cell, and render_to_string are all already target-agnostic.
// To do native SSR:
//   1. Patch or wait for rabbita fix (one-line `#cfg` guard)
//   2. Change frontend/app `supported_targets` from "js" to "all"
//   3. Guard `update.mbt` HTTP imports with `#cfg(target="js")`
//   4. Backend imports frontend/app, calls `model.view(noop_dispatch)`
//   5. Use `render_to_string(static_cell(html))` to produce the HTML string
//   6. Inject into the HTML shell instead of empty `<div id="app"></div>`

///|
/// Render an `Html` node to its HTML string representation for test assertions.
#warnings("-alert_unstable")
fn render(html : @rabbita.Html) -> String {
  @rabbita.render_to_string(@rabbita.static_cell(html))
}

// ── Full view ───────────────────────────────────────────────────────

///|
test "view shows initial empty state with no people" {
  inspect(render(empty_model().view(noop_dispatch)), content=(
    #|<div style="max-width: 520px;margin: 0 auto;padding: 24px 16px;font-family: -apple-system, BlinkMacSystemFont, &#39;Segoe UI&#39;, Roboto, sans-serif"><div style="text-align: center;margin-bottom: 24px;padding-top: 12px"><h1 style="color: white;font-size: 26px;font-weight: 800;margin-bottom: 4px;letter-spacing: -0.5px">Splitwise</h1><p style="color: rgba(255,255,255,0.75);font-size: 13px">Split expenses with friends</p></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">People</h2><form style="display: flex;gap: 8px;margin-bottom: 12px"><input type="text" autocomplete="off" placeholder="Enter a name..." style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><button type="submit" style="padding: 10px 20px;background: #667eea;color: white;border: none;border-radius: 10px;cursor: pointer;font-size: 14px;font-weight: 600">Add</button></form><p style="color: #aaa;font-size: 13px;text-align: center;padding: 12px 0">Add at least 2 people to get started</p></div></div>
  ))
}

///|
test "view shows people chips when people exist" {
  let model = {
    ..empty_model(),
    people: [{ id: 1, name: "Alice" }, { id: 2, name: "Bob" }],
  }
  inspect(render(model.view(noop_dispatch)), content=(
    #|<div style="max-width: 520px;margin: 0 auto;padding: 24px 16px;font-family: -apple-system, BlinkMacSystemFont, &#39;Segoe UI&#39;, Roboto, sans-serif"><div style="text-align: center;margin-bottom: 24px;padding-top: 12px"><h1 style="color: white;font-size: 26px;font-weight: 800;margin-bottom: 4px;letter-spacing: -0.5px">Splitwise</h1><p style="color: rgba(255,255,255,0.75);font-size: 13px">Split expenses with friends</p></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">People</h2><form style="display: flex;gap: 8px;margin-bottom: 12px"><input type="text" autocomplete="off" placeholder="Enter a name..." style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><button type="submit" style="padding: 10px 20px;background: #667eea;color: white;border: none;border-radius: 10px;cursor: pointer;font-size: 14px;font-weight: 600">Add</button></form><div style="display: flex;flex-wrap: wrap;gap: 8px"><div style="display: inline-flex;align-items: center;gap: 8px;padding: 6px 14px 6px 6px;background: #f8f8ff;border-radius: 24px;font-size: 13px;color: #333"><div style="width: 26px;height: 26px;border-radius: 50%;background: #667eea;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">A</div><span style="font-weight: 500">Alice</span></div><div style="display: inline-flex;align-items: center;gap: 8px;padding: 6px 14px 6px 6px;background: #f8f8ff;border-radius: 24px;font-size: 13px;color: #333"><div style="width: 26px;height: 26px;border-radius: 50%;background: #e91e63;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">B</div><span style="font-weight: 500">Bob</span></div></div></div><div style="backg