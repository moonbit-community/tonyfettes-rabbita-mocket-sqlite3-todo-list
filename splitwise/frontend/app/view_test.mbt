ent: center">X</button></div></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">Who Owes Who</h2><div style="display: flex;align-items: center;gap: 10px;padding: 12px 0;border-bottom: 1px solid #f5f5f5"><div style="display: flex;align-items: center;gap: 6px;flex: 1"><div style="width: 30px;height: 30px;border-radius: 50%;background: #e91e63;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">B</div><span style="font-weight: 600;font-size: 14px">Bob</span></div><div style="color: #ccc;font-size: 18px;padding: 0 4px">-&gt;</div><div style="display: flex;align-items: center;gap: 6px;flex: 1"><div style="width: 30px;height: 30px;border-radius: 50%;background: #667eea;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">A</div><span style="font-weight: 600;font-size: 14px">Alice</span></div><span style="font-weight: 700;font-size: 15px;color: #43a047;background: #e8f5e9;padding: 4px 10px;border-radius: 8px">$2.50</span></div><div style="display: flex;align-items: center;gap: 10px;padding: 12px 0;border-bottom: 1px solid #f5f5f5"><div style="display: flex;align-items: center;gap: 6px;flex: 1"><div style="width: 30px;height: 30px;border-radius: 50%;background: #00bcd4;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">C</div><span style="font-weight: 600;font-size: 14px">Carol</span></div><div style="color: #ccc;font-size: 18px;padding: 0 4px">-&gt;</div><div style="display: flex;align-items: center;gap: 6px;flex: 1"><div style="width: 30px;height: 30px;border-radius: 50%;background: #667eea;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">A</div><span style="font-weight: 600;font-size: 14px">Alice</span></div><span style="font-weight: 700;font-size: 15px;color: #43a047;background: #e8f5e9;padding: 4px 10px;border-radius: 8px">$10.00</span></div></div></div>
  ))
