///|
test "view shows all-settled-up when expenses exist but no settlements" {
  let people : Array[@shared.Person] = [
    { id: 1, name: "Alice" },
    { id: 2, name: "Bob" },
  ]
  // Each person paid the same amount, split the same way -> no settlements
  let expenses : Array[@shared.Expense] = [
    { id: 1, description: "Lunch", amount: 1000, paid_by: 1, split_among: [1, 2] },
    { id: 2, description: "Dinner", amount: 1000, paid_by: 2, split_among: [1, 2] },
  ]
  let settlements = @shared.compute_settlements(people, expenses)
  let model = { ..empty_model(), people, expenses, settlements }
  inspect(render(model.view(noop_dispatch)), content=(
    #|<div style="max-width: 520px;margin: 0 auto;padding: 24px 16px;font-family: -apple-system, BlinkMacSystemFont, &#39;Segoe UI&#39;, Roboto, sans-serif"><div style="text-align: center;margin-bottom: 24px;padding-top: 12px"><h1 style="color: white;font-size: 26px;font-weight: 800;margin-bottom: 4px;letter-spacing: -0.5px">Splitwise</h1><p style="color: rgba(255,255,255,0.75);font-size: 13px">Split expenses with friends</p></div><div style="background: rgba(255,255,255,0.15);border-radius: 12px;padding: 16px 20px;margin-bottom: 16px;text-align: center;backdrop-filter: blur(10px)"><div style="color: rgba(255,255,255,0.7);font-size: 12px;margin-bottom: 4px;text-transform: uppercase;letter-spacing: 1px">Total Expenses</div><div style="color: white;font-size: 32px;font-weight: 800">$20.00</div></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">People</h2><form style="display: flex;gap: 8px;margin-bottom: 12px"><input type="text" autocomplete="off" placeholder="Enter a name..." style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><button type="submit" style="padding: 10px 20px;background: #667eea;color: white;border: none;border-radius: 10px;cursor: pointer;font-size: 14px;font-weight: 600">Add</button></form><div style="display: flex;flex-wrap: wrap;gap: 8px"><div style="display: inline-flex;align-items: center;gap: 8px;padding: 6px 14px 6px 6px;background: #f8f8ff;border-radius: 24px;font-size: 13px;color: #333"><div style="width: 26px;height: 26px;border-radius: 50%;background: #667eea;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">A</div><span style="font-weight: 500">Alice</span></div><div style="display: inline-flex;align-items: center;gap: 8px;padding: 6px 14px 6px 6px;background: #f8f8ff;border-radius: 24px;font-size: 13px;color: #333"><div style="width: 26px;height: 26px;border-radius: 50%;background: #e91e63;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">B</div><span style="font-weight: 500">Bob</span></div></div></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">Add Expense</h2><form style="display: flex;flex-direction: column;gap: 10px"><input type="text" autocomplete="off" placeholder="What was it for?" style="padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><div style="display: flex;gap: 10px"><input type="text" autocomplete="off" placeholder="0.00" style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><select style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none;background: white;color: #333"><option value="1" selected>Alice paid</option><option value="2">Bob paid</option></select></div><div style="font-size: 12px;color: #999;padding: 0 2px">Split equally among all 2 people</div><button type="submit" style="padding: 12px;background: linear-gradient(135deg, #667eea, #764ba2);color: white;border: none;border-radius: 10px;cursor: pointer;font-size: 15px;font-weight: 600;margin-top: 2px">Add Expense</button></form></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">Expenses</h2><div style="display: flex;align-items: center;gap: 12px;padding: 10px 0;border-bottom: 1px solid #f5f5f5"><div style="width: 36px;height: 36px;border-radius: 50%;flex-shrink: 0;background: #667eea;color: white;font-size: 14px;font-weight: 700;display: flex;align-items: center;justify-content: center">A</div><div style="flex: 1;min-width: 0"><div style="font-weight: 600;font-size: 14px;margin-bottom: 1px">Lunch</div><div style="font-size: 12px;color: #999">Alice paid · 2 way split</div></div><span style="font-weight: 700;font-size: 15px;color: #333;white-space: nowrap">$10.00</span><button style="width: 28px;height: 28px;background: #fee;color: #e53935;border: none;border-radius: 8px;cursor: pointer;font-size: 13px;font-weight: 700;flex-shrink: 0;display: flex;align-items: center;justify-content: center">X</button></div><div style="display: flex;align-items: center;gap: 12px;padding: 10px 0;border-bottom: 1px solid #f5f5f5"><div style="width: 36px;height: 36px;border-radius: 50%;flex-shrink: 0;background: #e91e63;color: white;font-size: 14px;font-weight: 700;display: flex;align-items: center;justify-content: center">B</div><div style="flex: 1;min-width: 0"><div style="font-weight: 600;font-size: 14px;margin-bottom: 1px">Dinner</div><div style="font-size: 12px;color: #999">Bob paid · 2 way split</div></div><span style="font-weight: 700;font-size: 15px;color: #333;white-space: nowrap">$10.00</span><button style="width: 28px;height: 28px;background: #fee;color: #e53935;border: none;border-radius: 8px;cursor: pointer;font-size: 13px;font-weight: 700;flex-shrink: 0;display: flex;align-items: center;justify-content: center">X</button></div></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">Settlements</h2><p style="text-align: center;color: #43a047;padding: 20px 0;font-weight: 600;font-size: 15px">All settled up!</p></div></div>
  ))
}

