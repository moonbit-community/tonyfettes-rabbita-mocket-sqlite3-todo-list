///|
test "view preserves person input value" {
  let model = { ..empty_model(), person_input: "draft" }
  inspect(render(model.view(noop_dispatch)), content=(
    #|<div style="max-width: 520px;margin: 0 auto;padding: 24px 16px;font-family: -apple-system, BlinkMacSystemFont, &#39;Segoe UI&#39;, Roboto, sans-serif"><div style="text-align: center;margin-bottom: 24px;padding-top: 12px"><h1 style="color: white;font-size: 26px;font-weight: 800;margin-bottom: 4px;letter-spacing: -0.5px">Splitwise</h1><p style="color: rgba(255,255,255,0.75);font-size: 13px">Split expenses with friends</p></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">People</h2><form style="display: flex;gap: 8px;margin-bottom: 12px"><input type="text" autocomplete="off" placeholder="Enter a name..." style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value="draft"></input><button type="submit" style="padding: 10px 20px;background: #667eea;color: white;border: none;border-radius: 10px;cursor: pointer;font-size: 14px;font-weight: 600">Add</button></form><p style="color: #aaa;font-size: 13px;text-align: center;padding: 12px 0">Add at least 2 people to get started</p></div></div>
  ))
}

