enter;gap: 8px;padding: 6px 14px 6px 6px;background: #f8f8ff;border-radius: 24px;font-size: 13px;color: #333"><div style="width: 26px;height: 26px;border-radius: 50%;background: #e91e63;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">B</div><span style="font-weight: 500">Bob</span></div><div style="display: inline-flex;align-items: center;gap: 8px;padding: 6px 14px 6px 6px;background: #f8f8ff;border-radius: 24px;font-size: 13px;color: #333"><div style="width: 26px;height: 26px;border-radius: 50%;background: #00bcd4;color: white;font-size: 12px;font-weight: 700;display: flex;align-items: center;justify-content: center">C</div><span style="font-weight: 500">Carol</span></div></div></div><div style="background: white;border-radius: 14px;padding: 18px 20px;margin-bottom: 14px;box-shadow: 0 1px 8px rgba(0,0,0,0.06)"><h2 style="font-size: 13px;font-weight: 700;color: #999;margin-bottom: 14px;text-transform: uppercase;letter-spacing: 0.5px">Add Expense</h2><form style="display: flex;flex-direction: column;gap: 10px"><input type="text" autocomplete="off" placeholder="What was it for?" style="padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><div style="display: flex;gap: 10px"><input type="text" autocomplete="off" placeholder="0.00" style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none" value=""></input><select style="flex: 1;padding: 10px 14px;border: 2px solid #eee;border-radius: 10px;font-size: 14px;outline: none;background: white;color: #333"><option value="1" selected>Alice paid</option><option value="2">Bob paid</option><option value="3">Carol paid</option></select></div><div style="font-size: 12px;color: #999;padding: 0 2px">Split equally among all 3 people</div><button type="submit" style="padding: 12px;background: linear-gradient(135deg, #667eea, #764ba2);color: white;border: none;border-radius: 10